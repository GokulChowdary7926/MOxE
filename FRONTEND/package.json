{
  "name": "moxe-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "licenses:gen": "node scripts/generate-open-source-licenses.mjs",
    "check:mock-imports": "node scripts/check-mock-imports.mjs",
    "test": "npm run check:mock-imports && NODE_ENV=test jest --config jest.config.cjs",
    "test:watch": "NODE_ENV=test jest --config jest.config.cjs --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:headed": "playwright test --headed",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "@sentry/react": "^7.120.4",
    "@sentry/tracing": "^7.120.4",
    "@tanstack/react-query": "^5.0.0",
    "algoliasearch": "^5.13.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.294.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-leaflet": "^4.2.1",
    "react-redux": "^9.0.0",
    "react-router-dom": "^6.20.0",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.49.1",
    "@types/jest": "^29.5.14",
    "@types/leaflet": "^1.9.8",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.16",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.2.2",
    "vite": "^6.4.2"
  }
}
