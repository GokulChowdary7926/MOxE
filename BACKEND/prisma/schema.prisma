  createdAt DateTime @default(now())
  account   Account  @relation(fields: [accountId], references: [id])
  reel      Reel     @relation(fields: [reelId], references: [id])

  @@unique([accountId, reelId])
  @@index([reelId])
}

model ReelComment {
  id        String   @id @default(cuid())
