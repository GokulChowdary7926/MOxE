// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum AccountType {
  PERSONAL
  BUSINESS
  CREATOR
  JOB
}

enum SubscriptionTier {
  FREE
  STAR
  THICK
}

enum ContentType {
  POST
  STORY
  REEL
  LIVE
}

enum PrivacyLevel {
  PUBLIC
  FOLLOWERS_ONLY
  CLOSE_FRIENDS_ONLY
  ONLY_ME
}

enum SearchVisibility {
  EVERYONE
  FOLLOWERS_ONLY
  NO_ONE
}

// ==================== USERS & ACCOUNTS ====================

model User {
  id                String   @id @default(cuid())
  phoneNumber       String   @unique
  email             String?  @unique
  emailVerified     Boolean  @default(false)
  password          String
  dateOfBirth       DateTime
  isVerified        Boolean  @default(false)
  verificationLevel String? // "BASIC", "ID_VERIFIED", "BUSINESS_VERIFIED", etc.
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  accounts        Account[]
  sessions        Session[]
  securityLogs    SecurityLog[]
  devices         Device[]
  userEmbeddings  UserEmbedding[]

  @@index([phoneNumber])
  @@index([email])
}

model PhoneVerification {
  id         String   @id @default(cuid())
  phoneNumber String
  code       String   // 6-digit
  expiresAt  DateTime
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([phoneNumber])
  @@index([expiresAt])
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
  @@index([userId])
}

model Video {
  id              String   @id @default(cuid())
  accountId       String
  title           String   @db.VarChar(200)
  description     String?  @db.VarChar(5000)
  url             String   @db.VarChar(500)
  fileSize        Int
  durationSeconds Int?
  visibility      String   @db.VarChar(20) @default("private") // private | unlisted | public
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt])
}

model Account {
  id               String           @id @default(cuid())
  userId           String
  username         String           @unique
  displayName      String
  accountType      AccountType
  subscriptionTier SubscriptionTier @default(FREE)
  bio              String?          @db.VarChar(300)
  profilePhoto     String?
  coverPhoto       String?
  pronouns         String?
  location         String?
  website          String? // For personal accounts (1 link)
  isPrivate        Boolean          @default(false)
  isActive         Boolean          @default(true)
  deactivatedAt    DateTime?
  verifiedBadge    Boolean          @default(false)
  verifiedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Personal account privacy & guide (roadmap)
  usernameChangedAt        DateTime?
  searchVisibility         SearchVisibility?  @default(EVERYONE)
  showActivityStatus       Boolean            @default(true)
  lastActiveAt             DateTime?
  storyArchiveEnabled      Boolean            @default(false)
  hideProfileVisits        Boolean            @default(false)
  anonymousStoryViewsUsed  Int                @default(0)
  anonymousStoryViewsResetAt DateTime?
  defaultStoryAllowReplies Boolean?           @default(true)
  defaultStoryAllowReshares Boolean?          @default(true)
  nearbyEnabled             Boolean           @default(false)
  nearbyQueryCountToday     Int               @default(0)   // 3.1 daily limit for getNearby
  nearbyQueryResetAt        DateTime?         // midnight reset
  nearbyPostCountToday      Int               @default(0)   // 4.1.1 nearby messaging posts (1 free/day paid, then $0.50 each)
  nearbyPostResetAt         DateTime?         // midnight reset for post count
  // Per-type notification preferences (Guide 1.7): likes, comments, dms, mentions, follows, storyReplies
  notificationPrefs Json?   // { likes?: boolean, comments?: boolean, dms?: boolean, mentions?: boolean, follows?: boolean, storyReplies?: boolean } default all true
  // Quiet mode (Guide 1.7.2): silence notifications during window
  quietModeEnabled  Boolean  @default(false)
  quietModeStart    String?  @db.VarChar(5)  // e.g. "22:00"
  quietModeEnd      String?  @db.VarChar(5)  // e.g. "07:00"
  quietModeDays     Json?    // [0,1,2,3,4,5,6] 0=Sun
  // Hidden words (1.6.5): filter comments and DM requests containing these words
  hiddenWords             Json?    // string[] – words/phrases to hide
  hiddenWordsCommentFilter Boolean @default(false)
  hiddenWordsDMFilter     Boolean  @default(false)
  // Creator 14.1: advanced comment filter sensitivity (LOW, MEDIUM, HIGH)
  commentFilterSensitivity String? @db.VarChar(20)

  // Business/Creator specific
  businessCategory         String?
  businessHours            Json? // Store as JSON
  contactEmail             String?
  contactPhone             String?
  contactBookingLink       String?   @db.VarChar(500) // Guide 8.1.3
  contactWhatsApp          String?   @db.VarChar(50)
  contactAddress           String?
  actionButtons            Json? // Store button configurations
  sellerTermsAcceptedAt    DateTime? // Seller responsibility acknowledgment (Guide 3.10)
  // Shop setup (Guide 3.5.2)
  shopBannerUrl            String?
  featuredProductIds       Json?    // string[] – product IDs to feature on shop
  // 2.20 Custom domain (paid): e.g. shop.example.com; verify via CNAME
  customDomain             String?  @db.VarChar(253)
  customDomainVerifiedAt   DateTime?
  // Seller verification (Guide 3.6.x) – PAN, GSTIN, bank for verified seller
  pan                      String?  @db.VarChar(20)
  gstin                    String?  @db.VarChar(20)
  bankDetails              Json?    // { last4?, bankName?, verifiedAt? }

  // Job account specific
  activeProfile        String?  @default("personal") @db.VarChar(20) // "personal" | "professional" for dual profile
  professionalHeadline String?
  professionalSection  Json? // Experience, education, etc.
  personalSection      Json? // Personal bio, interests, etc.
  skills               String[]
  workplaceVerified    Boolean  @default(false)
  openToOpportunities  Boolean  @default(false)
  // Feed interactions (lightweight ranking signals)
  feedInteractions FeedInteraction[]

  // Monetization
  subscriptionsEnabled     Boolean @default(false)
  subscriptionTierOffers   Json?   // Creator: [{ key, name, price, perks? }] e.g. MONTHLY_299, MONTHLY_499
  subscriptionWelcomeMessage String? @db.VarChar(1000) // Guide 9.1.1: auto-DM to new subscribers
  badgesEnabled             Boolean @default(false)
  giftsEnabled         Boolean @default(false)
  payoutMethod         Json?
  storageBytesUsed     Int      @default(0) // 1GB free, 5GB paid (4.2)

  // Relations
  user                       User               @relation(fields: [userId], references: [id])
  links                      Link[]
  posts                      Post[]
  postsAsCoAuthor            Post[]             @relation("PostCoAuthor")
  stories                    Story[]
  reels                      Reel[]
  lives                      Live[]
  followers                  Follow[]           @relation("following")
  following                  Follow[]           @relation("follower")
  followRequestsSent         FollowRequest[]    @relation("follow_requests_sent")
  followRequestsReceived     FollowRequest[]    @relation("follow_requests_received")
  closeFriends               CloseFriend[]      @relation("account_close_friends")
  closeFriendsAsFriend       CloseFriend[]      @relation("friend_close_friends")
  blockedUsers               Block[]            @relation("blocker")
  blockedByUsers             Block[]            @relation("blocked")
  mutedUsers                 Mute[]             @relation("muter")
  mutedByUsers               Mute[]             @relation("muted")
  restrictedUsers            Restrict[]         @relation("restrictor")
  restrictedByUsers          Restrict[]         @relation("restricted")
  limitInteractionSetting    LimitInteractionSetting?
  savedPosts                 SavedPost[]
  collections                Collection[]
  notifications              Notification[]     @relation("recipient")
  notificationsSent          Notification[]     @relation("sender")
  messages                   Message[]
  groupMembers               GroupMember[]
  groupAdmins                GroupAdmin[]
  tags                       Tag[]
  mentions                   Mention[]
  reactions                  Reaction[]
  comments                   Comment[]
  likes                      Like[]
  reelsLike                  ReelLike[]
  storyLikes                 StoryLike[]
  storyPollVotes              StoryPollVote[]
  storyReminders              StoryReminder[]
  storyQuestions              StoryQuestion[]
  storyEmojiRatings           StoryEmojiRating[]
  reelsComment               ReelComment[]
  reelsView                  ReelView[]
  views                      View[]
  shares                     Share[]
  reportsAsReporter          Report[]           @relation("reporter")
  reportsAsReported          Report[]           @relation("reported_account")
  jobAIHistory               JobAIAudit[]
  streaks                    Streak[]
  badges                     Badge[]
  achievements               Achievement[]
  moodHistory                MoodHistory[]
  locationHistory            LocationHistory[]
  safeZones                  SafeZone[]
  emergencyContacts          EmergencyContact[]
  emergencyContactsAsContact EmergencyContact[] @relation("emergency_contact")
  locationSharesAsSharer     LocationShare[]    @relation("sharer")
  locationSharesAsSharee     LocationShare[]    @relation("sharee")
  ordersAsBuyer              Order[]            @relation("buyer")
  ordersAsSeller             Order[]            @relation("seller")
  sellerCoupons              SellerCoupon[]     @relation("seller_coupons")
  reviewsAsSeller            Review[]           @relation("reviews_as_seller")
  reviewsAsReviewer          Review[]           @relation("reviews_as_reviewer")
  payouts                    Payout[]
  subscriptionsAsSubscriber  Subscription[]     @relation("subscriber")
  subscriptionsAsCreator     Subscription[]     @relation("creator")
  videos                     Video[]
  // Ads / campaigns owned by this account (Business / Creator).
  adCampaigns                AdCampaign[]
  adAudiences                AdAudience[]
  adFraudSignals             AdFraudSignal[]
  adFraudBlocks              AdFraudBlock[]
  // Ads billing (credits / invoices / limits)
  adBilling                  AdBillingAccount?

  // MOxE Job (Track, Know, Flow)
  jobPostings              JobPosting[]
  jobPostingsAsHiringManager JobPosting[]  @relation("JobPostingHiringManager")
  jobPostingsAsRecruiter     JobPosting[]  @relation("JobPostingRecruiter")
  jobApplications          JobApplication[]
  jobApplicationsDecidedBy  JobApplication[] @relation("JobApplicationDecidedBy")
  recruitmentCandidatesAdded RecruitmentCandidate[]
  interviewsCreated        Interview[]
  interviewFeedbacks       InterviewFeedback[]
  interviewInterviewers    InterviewInterviewer[]
  offersCreated            Offer[]
  workProjects             WorkProject[]

  // MOxE ACCESS (organizations / directory)
  orgMemberships           OrgUser[]
  orgInvitesSent           OrgInvitation[]      @relation("OrgInvitationSender")
  orgInvitesReceived       OrgInvitation[]      @relation("OrgInvitationRecipient")
  workProjectMemberships   WorkProjectMember[]
  workTasksAssigned        WorkTask[]         @relation("WorkTaskAssignee")
  workTaskComments         WorkTaskComment[]
  workTaskAttachments      WorkTaskAttachment[]
  pipelines                Pipeline[]
  flowBoards               FlowBoard[]
  flowBoardMembers         FlowBoardMember[]
  flowBoardInvitesCreated  FlowBoardInvite[] @relation("FlowBoardInviteInvitedBy")
  flowCardMembers          FlowCardMember[]
  flowCommentsAuthored     FlowComment[]    @relation("FlowCommentAuthor")
  flowAttachmentsUploaded  FlowAttachment[]
  trackProjects            TrackProject[]
  trackProjectMemberships  TrackProjectMember[]
  trackProjectsAsLead      TrackProject[]       @relation("TrackProjectLead")
  trackIssuesAssigned      TrackIssue[]         @relation("TrackIssueAssignee")
  trackIssuesCreated       TrackIssue[]         @relation("TrackIssueCreator")
  trackAttachmentsUploaded TrackAttachment[]
  salaryEntries            SalaryEntry[]
  companyReviews       CompanyReview[]
  careerResources      CareerResource[]
  interviewPreps       InterviewPrep[]
  knowledgeSpacesOwned KnowledgeSpace[]       @relation("KnowledgeSpaceOwner")
  knowledgeSpacePermissions KnowledgeSpacePermission[]
  knowledgePagesCreated KnowledgePage[]       @relation("KnowledgePageCreator")
  knowledgePagesUpdated KnowledgePage[]       @relation("KnowledgePageUpdater")
  knowledgePageVersions KnowledgePageVersion[]
  knowledgePageComments KnowledgePageComment[]
  knowledgePageAttachmentsUploaded KnowledgePageAttachment[]
  knowledgePagePermissions KnowledgePagePermission[]
  // MOxE TEAMS relations (JobTeam member/inviter)
  jobTeamMemberships   JobTeam[]            @relation("JobTeamMember")
  jobTeamInvitesSent   JobTeam[]            @relation("JobTeamInviter")
  codeReposOwned       CodeRepository[]       @relation("CodeRepoOwner")
  codeRepoCollaborators CodeRepoCollaborator[]
  codeCommitsAuthored  CodeCommit[]           @relation("CodeCommitAuthor")
  codePullRequestsAuthored CodePullRequest[]  @relation("CodePRAuthor")
  codePRReviewers      CodePRReviewer[]
  codePRComments       CodePRComment[]
  statusPagesOwned     StatusPage[]    @relation("StatusPageOwner")
  statusIncidentsAuthored StatusIncident[] @relation("StatusIncidentAuthor")
  statusIncidentUpdatesAuthored StatusIncidentUpdate[] @relation("StatusIncidentUpdateAuthor")
  hideStoryFrom        HideStoryFrom[]  @relation("hide_story_owner")
  hideStoryFromViewer  HideStoryFrom[]  @relation("hide_story_from")
  StoryView            StoryView[]
  StoryReply           StoryReply[]
  ArchivedStory        ArchivedStory[]
  Highlight            Highlight[]
  LiveViewer           LiveViewer[]
  LiveComment          LiveComment[]
  LiveBadge            LiveBadge[]
  LiveGift             LiveGift[]
  MessageRecipient     MessageRecipient[]
  pollVotes                 PollVote[]
  chatTicketsOwned     ChatTicket[]       @relation("ChatTicketOwner")
  chatTicketsAssigned   ChatTicket[]       @relation("ChatTicketAssigned")
  chatTicketsAsPeer    ChatTicket[]       @relation("ChatTicketPeer")
  supportTickets       SupportTicket[]
  jobDocumentsOwned    JobDocument[]      @relation("JobDocumentOwner")
  jobDocumentVersionsAuthored JobDocumentVersion[] @relation("JobDocumentVersionAuthor")
  jobDocumentCommentsAuthored JobDocumentComment[] @relation("JobDocumentCommentAuthor")
  pinnedChats          PinnedChat[]        @relation("pinned_chats_owner")
  pinnedChatsAsOther   PinnedChat[]        @relation("pinned_chats_other")
  conversationMutesOwner ConversationMute[] @relation("conversation_mutes_owner")
  conversationMutesPeer  ConversationMute[] @relation("conversation_mutes_peer")
  conversationLabelsOwner ConversationLabel[] @relation("conversation_labels_owner")
  conversationLabelsPeer  ConversationLabel[] @relation("conversation_labels_peer")
  messageTemplates        MessageTemplate[]
  autoResponseRules       AutoResponseRule[]
  creatorConnectionsOwner CreatorConnection[]  @relation("creator_connections_owner")
  creatorConnectionsPeer  CreatorConnection[]  @relation("creator_connections_peer")
  brandCampaignApplications BrandCampaignApplication[]
  reelBonuses            ReelBonus[]
  Group                Group[]
  HangoutSession       HangoutSession[]
  Challenge            Challenge[]
  ChallengeParticipant ChallengeParticipant[]
  Product              Product[]
  Payment              Payment[]
  Draft                Draft[]
  AnalyticsEvent       AnalyticsEvent[]
  promotions           Promotion[]
  businessMemberships  BusinessMember[]    @relation("business_owner")
  businessMemberOf     BusinessMember[]     @relation("member_account")
  businessQuickReplies BusinessQuickReply[]
  businessTeamActivities BusinessTeamActivity[] @relation("business_team_owner")
  productCollections   ProductCollection[]
  productWishlists     ProductWishlist[]
  carts                Cart[]
  verificationRequests VerificationRequest[]

  // Premium: messaging blocked users
  premiumMessageGrantsSent     PremiumMessageGrant[]     @relation("premium_grants_sent")
  premiumMessageGrantsReceived PremiumMessageGrant[]     @relation("premium_grants_received")
  premiumBlockedMessagesSent   PremiumBlockedMessage[]    @relation("premium_blocked_sent")
  premiumBlockedMessagesReceived PremiumBlockedMessage[]  @relation("premium_blocked_received")
  lifestyleStrikes             LifestyleStrike[]
  profileViewsAsOwner          ProfileView[]             @relation("profile_owner")
  profileViewsAsViewer         ProfileView[]             @relation("profile_viewer")
  anonymousSpacesCreated       AnonymousSpace[]
  anonymousPosts               AnonymousPost[]
  anonymousVotes               AnonymousVote[]
  anonymousComments            AnonymousComment[]
  proximityAlertsAsOwner       ProximityAlert[]          @relation("proximity_alerts_owner")
  proximityAlertsAsTarget      ProximityAlert[]          @relation("proximity_alerts_target")
  atlasObjectives              AtlasObjective[]
  atlasProgressUpdates         AtlasProgressUpdate[]
  translationSessionsAsCaller TranslationSession[]      @relation("translation_caller")
  translationSessionsAsCallee TranslationSession[]     @relation("translation_callee")
  translationUsage             TranslationUsage[]
  nearbyPostCharges            NearbyPostCharge[]
  alertSchedules               AlertSchedule[]
  alertScheduleParticipants    AlertScheduleParticipant[]
  alertDeliveries              AlertDelivery[]
  flowCardReminders            FlowCardReminder[]
  buildPipelines               BuildPipeline[]
  services                     Service[]
  serviceOwnerships            ServiceOwner[]
  strategyPlans                JobStrategyPlan[]
  jobIntegrations              JobIntegration[]
  jobTeams                     JobTeam[]
  savedJobSearches            SavedJobSearch[]

  @@unique([userId, username])
  @@index([username])
  @@index([accountType])
}

model Link {
  id           String   @id @default(cuid())
  accountId    String
  url          String
  title        String
  displayText  String?
  linkCategory String?  // Website, Shop, Menu, Book, Catering, etc.
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])

  @@unique([accountId, order])
}

// ==================== FOLLOWS & RELATIONSHIPS ====================

model Follow {
  id                   String   @id @default(cuid())
  followerId           String
  followingId          String
  isCloseFriend        Boolean  @default(false)
  isFavorite           Boolean  @default(false)
  notificationsEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())

  follower  Account @relation("follower", fields: [followerId], references: [id])
  following Account @relation("following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// When a user follows a private account, a request is created until the account owner approves/declines.
model FollowRequest {
  id          String   @id @default(cuid())
  requesterId String   // who wants to follow
  accountId   String   // the private account that receives the request
  createdAt   DateTime @default(now())

  requester Account @relation("follow_requests_sent", fields: [requesterId], references: [id], onDelete: Cascade)
  account   Account @relation("follow_requests_received", fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([requesterId, accountId])
  @@index([accountId])
}

model CloseFriend {
  id        String   @id @default(cuid())
  accountId String
  friendId  String
  createdAt DateTime @default(now())

  account Account @relation("account_close_friends", fields: [accountId], references: [id])
  friend  Account @relation("friend_close_friends", fields: [friendId], references: [id])

  @@unique([accountId, friendId])
}

model Block {
  id                   String    @id @default(cuid())
  blockerId            String
  blockedId            String
  blockFutureAccounts  Boolean   @default(false)
  expiresAt            DateTime? // null = permanent; set for temporary block (e.g. 7 days)
  createdAt            DateTime  @default(now())

  blocker Account @relation("blocker", fields: [blockerId], references: [id])
  blocked Account @relation("blocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
}

// ==================== PREMIUM: MESSAGING BLOCKED USERS ====================
// Premium (Star/Thick) users can send limited messages to users who blocked them.
// 2 grants per 28-day period; 14-day messaging window per grant; 150 chars (optional paid extension).

model PremiumMessageGrant {
  id                   String   @id @default(cuid())
  senderAccountId      String
  recipientAccountId   String
  grantedAt            DateTime @default(now())
  expiresAt            DateTime // 28 days from grant (period end)
  remainingDays        Int      @default(14) // days left in 14-day messaging window
  status               String   @default("active") // active, used, expired

  senderAccount   Account @relation("premium_grants_sent", fields: [senderAccountId], references: [id])
  recipientAccount Account @relation("premium_grants_received", fields: [recipientAccountId], references: [id])
  messages        PremiumBlockedMessage[]

  @@unique([senderAccountId, recipientAccountId])
  @@index([senderAccountId])
  @@index([recipientAccountId])
  @@index([expiresAt])
}

model PremiumBlockedMessage {
  id                String   @id @default(cuid())
  grantId           String
  senderId          String
  recipientId       String
  content           String   @db.VarChar(500) // 150 base + optional paid 150
  characterCount   Int
  paidExtension     Boolean  @default(false)
  sentAt            DateTime @default(now())
  dailyMessageCount Int     @default(1) // per-day limit within grant

  grant    PremiumMessageGrant           @relation(fields: [grantId], references: [id])
  sender   Account                       @relation("premium_blocked_sent", fields: [senderId], references: [id])
  recipient Account                      @relation("premium_blocked_received", fields: [recipientId], references: [id])
  actions  PremiumMessageRecipientAction[]

  @@index([grantId])
  @@index([recipientId])
  @@index([sentAt])
}

model PremiumMessageRecipientAction {
  id            String   @id @default(cuid())
  messageId     String
  action        String   // viewed, reblocked, reported, unblocked
  actionedAt    DateTime @default(now())
  reportReason  String?  @db.VarChar(50)
  reportDetails String?  @db.Text

  message PremiumBlockedMessage @relation(fields: [messageId], references: [id])

  @@index([messageId])
}

model LifestyleStrike {
  id                    String    @id @default(cuid())
  accountId             String
  strikeType            String    // PREMIUM_MESSAGE_ABUSE
  grantedAt             DateTime  @default(now())
  expiresAt             DateTime? // null = permanent until next tier change
  reason                String?   @db.Text
  associatedMessageId   String?

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([strikeType])
}

model Mute {
  id          String   @id @default(cuid())
  muterId     String
  mutedId     String
  mutePosts   Boolean  @default(true)
  muteStories Boolean  @default(true)
  createdAt   DateTime @default(now())

  muter Account @relation("muter", fields: [muterId], references: [id])
  muted Account @relation("muted", fields: [mutedId], references: [id])

  @@unique([muterId, mutedId])
}

model Restrict {
  id           String   @id @default(cuid())
  restrictorId String
  restrictedId String
  createdAt    DateTime @default(now())

  restrictor Account @relation("restrictor", fields: [restrictorId], references: [id])
  restricted Account @relation("restricted", fields: [restrictedId], references: [id])

  @@unique([restrictorId, restrictedId])
}

model LimitInteractionSetting {
  id           String    @id @default(cuid())
  accountId    String    @unique
  commentsFrom String    @default("everyone")
  dmsFrom      String    @default("everyone")
  duration     String    @default("24h")
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

// ==================== CONTENT ====================

model Post {
  id                   String       @id @default(cuid())
  accountId            String
  contentType          ContentType  @default(POST)
  media                Json // Array of media objects
  caption              String?      @db.VarChar(2200)
  altText              String?      @db.VarChar(500) // Accessibility; guide 2.1.7
  location             String?
  privacy              PrivacyLevel @default(PUBLIC)
  allowComments        Boolean      @default(true)
  hideLikeCount        Boolean      @default(false)
  screenshotProtection Boolean      @default(false)
  isArchived           Boolean      @default(false)
  isDeleted            Boolean      @default(false)
  deletedAt            DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  // For carousel
  isCarousel    Boolean @default(false)
  carouselItems Json? // Order and metadata

  // For scheduled posts (professional accounts)
  isScheduled  Boolean   @default(false)
  scheduledFor DateTime?
  isMature     Boolean   @default(false) // Hide from minors in feed

  // Creator: subscriber-only content (Guide 9.1.2)
  isSubscriberOnly   Boolean @default(false)
  subscriberTierKeys Json?   // optional tier keys that can view; null = any subscriber

  // Collab post (Guide 12.1)
  coAuthorId String?

  // Branded content (Guide 9.5)
  brandedContentBrandId String?
  brandedContentDisclosure Boolean @default(false)

  // Relations
  account      Account       @relation(fields: [accountId], references: [id])
  coAuthor     Account?      @relation("PostCoAuthor", fields: [coAuthorId], references: [id], onDelete: SetNull)
  tags         Tag[]
  mentions     Mention[]
  postHashtags PostHashtag[]
  likes        Like[]
  comments     Comment[]
  views        View[]
  shares       Share[]
  saves        SavedPost[]
  reports      Report[]
  ProductTag   ProductTag[]
  adCampaigns  AdCampaign[]

  feedInteractions FeedInteraction[]

  @@index([accountId])
  @@index([createdAt])
  @@index([privacy])
}

model Story {
  id                 String       @id @default(cuid())
  accountId          String
  media              String // URL to media
  type               String // "photo", "video", "text", "boomerang"
  duration           Int          @default(24) // hours until expiration
  expiresAt          DateTime
  privacy            PrivacyLevel @default(PUBLIC)
  isCloseFriendsOnly Boolean      @default(false)
  allowReplies       Boolean      @default(true)
  allowReshares      Boolean      @default(true)
  music              Json? // Music sticker data
  stickers           Json // Array of stickers
  textOverlay        Json? // Text elements
  drawings           Json? // Drawing data
  viewedCount            Int          @default(0)
  replyCount             Int          @default(0)
  screenshotProtection   Boolean      @default(false)
  isMature               Boolean      @default(false) // Hide from minors in feed
  isSubscriberOnly       Boolean      @default(false) // Creator 9.1.2
  subscriberTierKeys     Json?
  isScheduled            Boolean      @default(false) // Guide 11.4.2
  scheduledFor           DateTime?
  createdAt              DateTime     @default(now())

  // Relations
  account    Account         @relation(fields: [accountId], references: [id])
  viewers    StoryView[]
  replies    StoryReply[]
  likes      StoryLike[]
  pollVotes       StoryPollVote[]
  reminders       StoryReminder[]
  storyQuestions  StoryQuestion[]
  emojiRatings    StoryEmojiRating[]
  addYoursParentId String?
  addYoursParent   Story?   @relation("AddYoursResponses", fields: [addYoursParentId], references: [id], onDelete: SetNull)
  addYoursResponses Story[] @relation("AddYoursResponses")
  highlights HighlightItem[]
  View       View[]
  Share      Share[]
  Tag        Tag[]
  Mention    Mention[]
  ProductTag ProductTag[]
  reports    Report[]

  @@index([accountId])
  @@index([expiresAt])
  @@index([addYoursParentId])
}

model StoryReminder {
