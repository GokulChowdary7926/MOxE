# Database — PostgreSQL only (Prisma). Point this at any Postgres host: local Docker, Neon, Supabase,
# AWS RDS, or other managed Postgres.
#
# Local (example):
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/moxe?schema=public"
#
# External / cloud — paste the URI from your provider’s dashboard. Most require TLS:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST.region.provider.com:5432/DATABASE?schema=public&sslmode=require"
#
# Neon / Supabase often give two URLs: use the pooled one for the app; if `prisma migrate deploy` fails
# behind a pooler, add a direct (non-pooled) URL — see Prisma “Neon” or “PgBouncer” docs, or set:
# DIRECT_URL="postgresql://..."  and add `directUrl = env("DIRECT_URL")` in prisma/schema.prisma datasource.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/moxe?schema=public"

# Prisma seed: off by default so E2E/bot accounts are not recreated in shared DBs.
# Playwright / local E2E: MOXE_ALLOW_E2E_SEED=1 npx prisma db seed
# Purge bot & seed-pattern posts: npm run cleanup:bots (dry run) or npm run cleanup:bots:apply
# MOXE_ALLOW_E2E_SEED=1

# Server
PORT=5007
CLIENT_URL=http://localhost:3000

# Comma-separated extra browser origins for CORS + Socket.IO (custom domain, staging, mobile web).
# ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com

# Global /api rate limit (requests per IP per 15 minutes). /api/health/* is not counted.
# API_RATE_LIMIT_MAX=300

# Upload URLs: used when returning URLs for uploaded files (e.g. in create post).
# Set to your API base URL so /uploads/<filename> is reachable by the frontend.
# UPLOAD_BASE_URL takes precedence; otherwise API_URL or CLIENT_URL is used (default http://localhost:5007).
# API_URL=https://api.yourdomain.com
# UPLOAD_BASE_URL=https://api.yourdomain.com

# Auth
JWT_SECRET=your-secret-key

# Platform admin (comma-separated Account IDs). Those users can call admin APIs and pass
# ProtectedRoute with requiredRole="ADMIN" when isPlatformAdmin is set on /me bundle.
# ADMIN_ACCOUNT_IDS=cuid1,cuid2

# Google OAuth (Log in with Google) – create credentials at https://console.cloud.google.com/apis/credentials
# Redirect URI in Google Console must be: {BACKEND_URL}/api/auth/google/callback (e.g. http://localhost:5007/api/auth/google/callback)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Optional: default is {BACKEND_URL}/api/auth/google/callback
# GOOGLE_REDIRECT_URI=http://localhost:5007/api/auth/google/callback
# Optional: backend base URL for default redirect (default http://localhost:5007)
# BACKEND_URL=http://localhost:5007

# Phone verification (Twilio) – do not commit real values; set in .env only
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Spotify API (music search) – get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Job → Integrations OAuth (POST /api/job/integrations/:provider/auth, callback /api/job/integrations/oauth/callback)
# Register the callback URL on each provider. Optional override:
# INTEGRATION_OAUTH_REDIRECT_URI=https://your-api.example.com/api/job/integrations/oauth/callback
#
# GitHub: https://github.com/settings/developers
# INTEGRATION_GITHUB_CLIENT_ID=
# INTEGRATION_GITHUB_CLIENT_SECRET=
# optional: INTEGRATION_GITHUB_SCOPE=read:user repo read:org
#
# GitLab: https://gitlab.com/-/user_settings/applications
# INTEGRATION_GITLAB_CLIENT_ID=
# INTEGRATION_GITLAB_CLIENT_SECRET=
#
# Slack: https://api.slack.com/apps → OAuth & Permissions
# SLACK_INTEGRATION_CLIENT_ID=
# SLACK_INTEGRATION_CLIENT_SECRET=
#
# Atlassian (Jira Cloud): https://developer.atlassian.com/console/myapps/
# ATLASSIAN_INTEGRATION_CLIENT_ID=
# ATLASSIAN_INTEGRATION_CLIENT_SECRET=
#
# Linear: https://linear.app/settings/api
# LINEAR_INTEGRATION_CLIENT_ID=
# LINEAR_INTEGRATION_CLIENT_SECRET=
#
# Notion: https://www.notion.so/my-integrations
# NOTION_INTEGRATION_CLIENT_ID=
# NOTION_INTEGRATION_CLIENT_SECRET=

# MOxE Mail (Track Recruiter — sendCandidateEmail). First configured provider wins.
# MOXE_MAIL_ENABLED=false   # hard off: no webhook/Resend/SendGrid/SES
# MOxE_MAIL_URL=            # or MAIL_WEBHOOK_URL — POST JSON { to, subject, body, templateId, personalization, source }
# RESEND_API_KEY=           # https://resend.com — optional RESEND_FROM
# SENDGRID_API_KEY=         # optional SENDGRID_FROM or MOXE_MAIL_FROM
# MOXE_MAIL_USE_SES=true    # requires MOXE_MAIL_SES_FROM (verified SES identity) + AWS_REGION + AWS credentials

# MOxE Calendar (Track interviews + Flow — createInterviewEvent / createFlowTaskEvent). Webhook first, then optional Google.
# MOXE_CALENDAR_ENABLED=false
# MOxE_CALENDAR_URL=        # or CALENDAR_WEBHOOK_URL — POST JSON (see moxe-calendar.service.ts)
# MOXE_CALENDAR_GOOGLE=true # Google Calendar API (user OAuth refresh token)
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REFRESH_TOKEN=
# GOOGLE_CALENDAR_ID=primary   # or shared calendar ID
# MOXE_CALENDAR_TIMEZONE=UTC

# Web Push (VAPID). Required for browser push subscription; without these, GET /api/push/vapid-public-key returns 503.
# Generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Live gifts & badges (NBK-023). Default: mock purchase IDs (no payment). Enable Stripe:
# LIVE_STRIPE_ENABLED=true
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_CURRENCY=usd
# Flow: POST /api/live/:liveId/badges/payment-intent → confirm with Stripe.js → POST /api/live/:liveId/badges { tier, amount, paymentIntentId }

# Commerce custom domain (NBK-024). Sellers CNAME their hostname to this target; POST /api/commerce/custom-domain/verify checks DNS.
# COMMERCE_CUSTOM_DOMAIN_CNAME_TARGET=commerce.yourplatform.com
# Non-production only: skip DNS and mark verified (explicit opt-in)
# COMMERCE_DOMAIN_VERIFY_MOCK=true
