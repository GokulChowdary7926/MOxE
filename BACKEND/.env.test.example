# Copy to `.env.test` and adjust for local PostgreSQL. Use only for non-production E2E.
# Example:
#   cp .env.test.example .env.test
#   createdb moxe_test
#   DATABASE_URL=... npx prisma migrate deploy
#   MOXE_ALLOW_E2E_SEED=1 DATABASE_URL=... npx prisma db seed

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/moxe_test?schema=public"
NODE_ENV="test"
JWT_SECRET="test-jwt-secret-do-not-use-in-production"
PORT=5007
CLIENT_URL="http://127.0.0.1:3001"
