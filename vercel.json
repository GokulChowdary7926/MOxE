{
  "version": 2,
  "builds": [
    {
      "src": "FRONTEND/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "FRONTEND/dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://moxe-backend.onrender.com/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/FRONTEND/dist/$1"
    }
  ],
  "env": {
    "VITE_API_URL": "https://moxe-backend.onrender.com/api"
  }
}

